# Environment template for the Edify API (Django). Copy to `.env` and fill in.
# Every variable here is actually read by config/settings/base.py or prod.py —
# see DEPLOY.md for the full production table.

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
# Either a single URL…
DATABASE_URL=postgresql://edify:YOUR_PASSWORD@localhost:5432/edify_pm
# …or discrete parts (used by docker-compose to build its own URL):
POSTGRES_USER=edify
POSTGRES_PASSWORD=                # REQUIRED — set a strong password
POSTGRES_DB=edify_pm
DB_PORT=5432

# ── Secrets (REQUIRED in production; prod refuses to boot without them) ─────
# Strong secret, ≥16 chars, must NOT contain "change-me"/"dev-only".
# Generate one:  openssl rand -hex 32
JWT_SECRET=
# The one bootstrap account that ships to production (created/updated by
# `manage.py seed`). Gets app Admin role + Django /admin/ access.
SUPER_ADMIN_EMAIL=domario@edify.org
SUPER_ADMIN_PASSWORD=             # REQUIRED — strong secret

# ── Production gates (prod.py fails closed on wrong values) ─────────────────
# Must be "enforce" in production. "shadow" is for local development only.
AUTHZ_MODE=enforce
# Absolute, persistent path (mounted volume) — evidence files live here.
EVIDENCE_STORAGE_DIR=/data/evidence
# Comma-separated real hosts. In prod, required unless RAILWAY_PUBLIC_DOMAIN
# is present (Railway injects it automatically).
ALLOWED_HOSTS=
# All of these MUST be false in production (prod.py refuses to boot otherwise).
# ENABLE_DEV_SEED=true enables `seed --demo` locally — flip it only in local dev.
ENABLE_MOCK_DATA=false
ENABLE_DEV_ENDPOINTS=false
ENABLE_DEV_SEED=false
ENABLE_DEV_IMPORTS=false
PARTNER_ROLE_BRIDGE=false

# ── Server ───────────────────────────────────────────────────────────────────
PORT=4000
# Public URL(s) of any cross-origin client, comma-separated (CORS).
CORS_ORIGINS=
# Run `manage.py seed` on container start (reference data only; idempotent).
# Set true for the first deploy, then back to false.
RUN_SEED=false
# The 8 scheduled jobs only run in the dedicated `manage.py runscheduler`
# process — set true THERE (and in local dev if you want jobs).
ENABLE_BACKGROUND_JOBS=false

# ── Optional ─────────────────────────────────────────────────────────────────
# Redis cache (falls back to in-process LocMem if unset/unreachable).
REDIS_URL=
# Optional outbound email is not required for login or in-app messaging.
# Keep "console" unless a future release explicitly enables external email.
# Analytics schedules deliver to Messages + Notifications, not email.
EMAIL_PROVIDER=console
RESEND_API_KEY=
# 32-byte hex/base64 key for AES-256-GCM field-level encryption.
FIELD_ENCRYPTION_KEY=
# ClamAV daemon for evidence-upload malware scanning (skipped if unset).
CLAMAV_HOST=
CLAMAV_PORT=3310
# Local development only — shared password for `seed --demo` accounts.
DEMO_LOGIN_PASSWORD=edify
