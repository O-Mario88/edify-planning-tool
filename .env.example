# docker-compose environment. Copy to `.env` and fill in before `docker compose up`.

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=edify
POSTGRES_PASSWORD=                # REQUIRED — set a strong password
POSTGRES_DB=edify_pm
DB_PORT=5432

# ── API ──────────────────────────────────────────────────────────────────────
API_PORT=4000
# REQUIRED — strong secret, ≥16 chars, must NOT contain "change-me"/"dev-only".
# Generate one:  openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=12h
# Public URL(s) of the web app, comma-separated (for CORS).
CORS_ORIGINS=http://localhost:3000
# Set true ONCE on first boot to seed demo data, then set back to false.
RUN_SEED=false

# ── Shared (api + web MUST match) ────────────────────────────────────────────
# The web→api bridge logs role-mapped accounts into the API with this password;
# a mismatch makes every proxied data call 401. Keep the two services in sync.
DEMO_LOGIN_PASSWORD=edify

# ── Web ──────────────────────────────────────────────────────────────────────
WEB_PORT=3000
# REQUIRED — signs the session cookie. Login returns 503 in production if unset.
# Generate one:  openssl rand -hex 32
EDIFY_SESSION_SECRET=
# Always-on super-admin login (the one account that persists across redeploys).
SUPER_ADMIN_EMAIL=domario@edify.org
SUPER_ADMIN_PASSWORD=             # REQUIRED — strong secret
