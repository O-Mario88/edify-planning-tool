# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
# edify-api (Django + DRF) — ignore its venv + build output
/edify-api/.venv
/edify-api/staticfiles
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# evidence storage (runtime; seed writes sample files here)
/uploads

# ── Local test data must NEVER be committed ──────────────────────────────────
# Local DB files / dumps
*.sqlite3
*.db
*.dump
*.sql.gz
# Local media / evidence uploads
edify-api/media/
edify-api/uploads/
# Local import files (CSV/XLSX used for local-test uploads)
/imports/
/edify-api/imports/
*.local.csv
*.local.xlsx
# Dev seed output / local generated data
/seed-output/
# Test evidence uploads
/test-uploads/
