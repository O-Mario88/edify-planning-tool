// Edify Planning & Monitoring Tool — data model.
//
// Principles encoded here:
//  • School Directory is the source of truth. Every operational record traces
//    back to a School (schoolId) or a Cluster.
//  • Salesforce-ready from day one: SV-/TS- IDs and sync fields exist, but
//    Salesforce is NOT integrated yet (manual entry + IA confirmation).
//  • Stable ids (cuid), createdAt/updatedAt everywhere, soft delete (deletedAt)
//    where records must not be hard-removed.
//  • FY = Oct 1 → Sep 30. Quarter + cumulative logic lives in code (fy util).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Enums ───────────────────────────

enum EdifyRole {
  CCEO
  CountryProgramLead
  CountryDirector
  RegionalVicePresident
  ImpactAssessment
  ProgramAccountant
  HumanResources
  ProjectCoordinator
  PartnerAdmin
  PartnerFieldOfficer
  Admin
}

enum SchoolType {
  client
  core
  potential_core
  champion
  potential_champion
  other
}

enum AccountOwnerStatus {
  matched
  unmatched
  pending
}

enum DuplicateStatus {
  none
  potential
  confirmed
  not_duplicate
  merged
}

enum ClusterStatus {
  unclustered
  clustered
  needs_review
}

// Status of a Cluster RECORD (vs. a school's clusterStatus above).
enum ClusterRecordStatus {
  active
  needs_review // created via sub-county override
  inactive
}

enum ClusterType {
  client
  core
  mixed
}

enum SsaStatus {
  not_done
  scheduled
  partner_assigned
  done
}

enum PlanningReadiness {
  locked
  limited
  ready
}

enum SsaIntervention {
  teaching_and_learning
  financial_health
  christlike_behaviour
  exposure_to_word_of_god
  government_requirements
  leadership
  education_technology
  learning_environment
}

enum ActivityType {
  school_visit
  follow_up_visit
  coaching_visit
  in_school_support
  training
  school_improvement_training
  cluster_meeting
  cluster_training
  ssa_activity
  project_activity
  partner_activity
  core_visit
  core_training
}

// Explicit cluster-meeting slot identity — a cluster activity can be tagged as
// the SIT or the 1st/2nd/3rd meeting, so slot status is read from the tag rather
// than inferred from ordering. Null for non-cluster (or untagged legacy) work.
enum ClusterMeetingSlot {
  sit
  first_meeting
  second_meeting
  third_meeting
}

enum DeliveryType {
  staff
  partner
}

enum ActivityStatus {
  not_planned
  planned
  scheduled
  assigned_to_partner
  partner_scheduled
  in_progress
  evidence_uploaded
  evidence_accepted
  salesforce_id_required
  awaiting_ia_verification
  ia_verified
  accountant_confirmed
  completed
  returned
  rejected
  rescheduled
  cancelled
  deferred
}

enum EvidenceStatus {
  none
  uploaded
  accepted
  returned
  rejected
}

enum EvidenceKind {
  visit_form
  school_stamp
  attendance_form
  meeting_minutes
  resolutions
  evaluation_form
  assessment_form
  photo
  pdf
  project_report
  coaching_notes
}

enum VerificationStatus {
  pending
  confirmed
  returned
  flagged
}

enum SalesforceActivityType {
  visit
  training
}

enum SalesforceSyncStatus {
  not_synced
  pending
  synced
  error
}

enum PaymentStatus {
  none
  pending_ia
  ia_confirmed
  pl_approval_required
  pl_approved
  accountant_cleared
  paid
  netsuite_accountability
  closed
  rejected
}

enum PaymentPath {
  partner
  staff
}

enum ProjectCategory {
  intervention_specific
  pilot
  selective_limited
}

enum NotificationPriority {
  low
  normal
  high
  urgent
}

enum MessageStatus {
  unread
  read
  archived
}

enum BudgetView {
  summary
  detailed
}

enum StaffOnboardingState {
  pending
  active
  suspended
}

// ─────────────────────── Auth / RBAC ───────────────────────

model User {
  id                     String        @id @default(cuid())
  email                  String        @unique
  passwordHash           String
  name                   String
  roles                  EdifyRole[]
  activeRole             EdifyRole
  isActive               Boolean       @default(true)
  // Brute-force protection: lock after repeated failures (auth.service).
  failedLoginCount       Int           @default(0)
  lockedUntil            DateTime?
  // MFA seam (Phase 8 design): high-risk roles enrol TOTP; secret is stored
  // encrypted (field-crypto) when enrolment ships.
  mfaEnabled             Boolean       @default(false)
  mfaSecret              String?
  // Password-reset seam: store only a HASH of the reset token + its expiry.
  passwordResetTokenHash String?
  passwordResetExpires   DateTime?
  staffProfile           StaffProfile?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  deletedAt              DateTime?

  auditLogs     AuditLog[]     @relation("AuditActor")
  notifications Notification[]
  sentMessages  Message[]      @relation("MessageSender")
  partner       Partner?
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique // e.g. "school.upload", "budget.approve"
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
}

model RolePermission {
  id           String     @id @default(cuid())
  role         EdifyRole
  permission   Permission @relation(fields: [permissionId], references: [id])
  permissionId String
  createdAt    DateTime   @default(now())

  @@unique([role, permissionId])
}

// ─────────────────────── Staff / Supervisors ───────────────────────

model StaffProfile {
  id                String               @id @default(cuid())
  user              User                 @relation(fields: [userId], references: [id])
  userId            String               @unique
  staffNumber       String?              @unique
  title             String?
  primaryDistrict   District?            @relation("StaffPrimaryDistrict", fields: [primaryDistrictId], references: [id])
  primaryDistrictId String?
  onboardingState   StaffOnboardingState @default(pending)

  supervisorLinks       StaffSupervisorAssignment[] @relation("Supervisee")
  superviseeLinks       StaffSupervisorAssignment[] @relation("Supervisor")
  geographyLinks        StaffGeographyAssignment[]
  schoolLinks           StaffSchoolAssignment[]
  targetProfiles        StaffTargetProfile[]
  supportCapacities     StaffSupportCapacity[]
  ownedSchools          School[]                    @relation("SchoolAccountOwner")
  responsibleActivities Activity[]                  @relation("ActivityResponsible")
  monitoredActivities   Activity[]                  @relation("ActivityMonitor")
  leaves                Leave[]
  contextProfiles       StaffContextProfile[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// HR — staff leave requests (annual / sick / compassionate / unpaid).
model Leave {
  id               String       @id @default(cuid())
  staff            StaffProfile @relation(fields: [staffProfileId], references: [id])
  staffProfileId   String
  type             String // annual | sick | compassionate | unpaid
  startDate        String // ISO date
  endDate          String
  days             Int
  status           String       @default("pending") // pending | approved | rejected
  reason           String?
  reviewedByUserId String?
  reviewedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([staffProfileId])
  @@index([status])
}

// Saved reports — a generated, persisted summary computed from program data.
model Report {
  id              String   @id @default(cuid())
  title           String
  type            String // program_summary | ssa_performance | activity_pipeline
  fy              String
  scope           String   @default("country")
  createdByUserId String?
  summaryJson     Json
  createdAt       DateTime @default(now())

  @@index([type])
  @@index([fy])
}

model StaffSupervisorAssignment {
  id           String       @id @default(cuid())
  supervisee   StaffProfile @relation("Supervisee", fields: [superviseeId], references: [id])
  superviseeId String
  supervisor   StaffProfile @relation("Supervisor", fields: [supervisorId], references: [id])
  supervisorId String
  createdAt    DateTime     @default(now())

  @@unique([superviseeId, supervisorId])
  // Scope resolution looks up supervisees BY supervisorId (the @@unique leads
  // with superviseeId, so supervisorId queries were unindexed).
  @@index([supervisorId])
}

model StaffGeographyAssignment {
  id         String       @id @default(cuid())
  staff      StaffProfile @relation(fields: [staffId], references: [id])
  staffId    String
  region     Region?      @relation(fields: [regionId], references: [id])
  regionId   String?
  district   District?    @relation(fields: [districtId], references: [id])
  districtId String?
  createdAt  DateTime     @default(now())

  // Scope resolution loads a staff member's geography by staffId.
  @@index([staffId])
}

model StaffSchoolAssignment {
  id        String       @id @default(cuid())
  staff     StaffProfile @relation(fields: [staffId], references: [id])
  staffId   String
  school    School       @relation(fields: [schoolId], references: [id])
  schoolId  String
  createdAt DateTime     @default(now())

  @@unique([staffId, schoolId])
}

// CD/IA-set limit on how many UNIQUE schools a staff member may DIRECTLY support
// per FY. Once reached, self-assignment to a NEW school is blocked and partner
// assignment becomes the route. Partners are NOT capped.
model StaffSupportCapacity {
  id                        String       @id @default(cuid())
  staff                     StaffProfile @relation(fields: [staffId], references: [id])
  staffId                   String
  fy                        String // "2026"
  maxDirectSchoolsSupported Int
  setByUserId               String // CD/IA who set it
  setByRole                 EdifyRole // CountryDirector | ImpactAssessment
  effectiveFrom             DateTime?
  effectiveTo               DateTime?
  notes                     String?
  isActive                  Boolean      @default(true)
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  @@unique([staffId, fy])
  @@index([fy])
}

// Every assignment attempt — allowed or blocked — for accountability (spec §20).
model AssignmentAudit {
  id                String    @id @default(cuid())
  action            String // "assign.self" | "assign.partner" | "assign.staff"
  schoolId          String?
  activityId        String?
  assignerId        String
  assignerRole      EdifyRole
  assignedToType    String // "staff" | "partner"
  assignedStaffId   String?
  assignedPartnerId String?
  allowed           Boolean
  blockedReason     String?
  overrideUsed      Boolean   @default(false)
  overrideReason    String?
  createdAt         DateTime  @default(now())

  @@index([assignerId])
  @@index([schoolId])
  @@index([createdAt])
}

model StaffTargetProfile {
  id              String       @id @default(cuid())
  staff           StaffProfile @relation(fields: [staffId], references: [id])
  staffId         String
  fy              String // "2026"
  visitsTarget    Int          @default(0)
  trainingsTarget Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([staffId, fy])
}

// ─────────────────────── Geography ───────────────────────

model Region {
  id         String                     @id @default(cuid())
  name       String                     @unique
  code       String?                    @unique
  // Official COD-AB fields (HDX/OCHA). pcode e.g. "UG3" (Northern).
  pcode      String?                    @unique
  source     String? // "COD-AB" once imported from the official boundary file
  latitude   Float?
  longitude  Float?
  districts  District[]
  subRegions SubRegion[]
  schools    School[]
  clusters   Cluster[]
  staffGeo   StaffGeographyAssignment[]
  createdAt  DateTime                   @default(now())
}

// Sub-region (e.g. Lango, Acholi) — NOT an admin level in COD-AB. A CONTROLLED
// organizational mapping layer with explicit confidence + audit, never confused
// with the official boundary source. Districts link via subRegionId; uncertain
// links stay REVIEW_REQUIRED.
model SubRegion {
  id             String     @id @default(cuid())
  region         Region     @relation(fields: [regionId], references: [id])
  regionId       String
  name           String     @unique
  normalizedName String
  source         String     @default("CONTROLLED")
  confidence     String     @default("REVIEW_REQUIRED") // VERIFIED | REVIEW_REQUIRED
  verifiedBy     String?
  verifiedAt     DateTime?
  notes          String?
  districts      District[]
  createdAt      DateTime   @default(now())
}

model District {
  id           String                     @id @default(cuid())
  name         String
  code         String?                    @unique // canonical UG-D-* id
  // Official COD-AB fields. pcode e.g. "UG3083" (Lira).
  pcode        String?                    @unique
  source       String?
  region       Region                     @relation(fields: [regionId], references: [id])
  regionId     String
  subRegion    SubRegion?                 @relation(fields: [subRegionId], references: [id])
  subRegionId  String?
  counties     County[]
  subCounties  SubCounty[]
  schools      School[]
  clusters     Cluster[]
  staffGeo     StaffGeographyAssignment[]
  staffPrimary StaffProfile[]             @relation("StaffPrimaryDistrict")
  // Approx district centroid — feeds the Leadership context-fairness travel
  // burden (haversine spread across a staff member's covered districts). Null
  // until seeded, in which case travel burden stays "insufficient data".
  latitude     Float?
  longitude    Float?
  createdAt    DateTime                   @default(now())

  @@unique([regionId, name])
}

// County (COD-AB admin3) — the level between District and Sub-county.
model County {
  id             String      @id @default(cuid())
  district       District    @relation(fields: [districtId], references: [id])
  districtId     String
  name           String
  normalizedName String
  pcode          String?     @unique
  source         String?
  latitude       Float?
  longitude      Float?
  subCounties    SubCounty[]
  createdAt      DateTime    @default(now())

  @@unique([districtId, name])
}

model SubCounty {
  id           String             @id @default(cuid())
  name         String
  seeded       Boolean            @default(false) // true = temporary dev fixture (replace with official data)
  // Official COD-AB fields. pcode e.g. "UG30830101".
  pcode        String?            @unique
  source       String?
  latitude     Float?
  longitude    Float?
  district     District           @relation(fields: [districtId], references: [id])
  districtId   String
  county       County?            @relation(fields: [countyId], references: [id])
  countyId     String?
  parishes     Parish[]
  schools      School[]
  clusters     Cluster[]
  clusterLinks ClusterSubCounty[]
  createdAt    DateTime           @default(now())

  @@unique([districtId, name])
}

model Parish {
  id          String    @id @default(cuid())
  name        String
  // Parishes are NOT in COD-AB. Populated from the Uganda Administrative Units
  // Dataset 2022 (UG-AU-DS-2022). pcode/source/confidence track provenance.
  pcode       String?   @unique
  source      String?
  confidence  String? // NOT_IN_BOUNDARY_SOURCE until verified
  subCounty   SubCounty @relation(fields: [subCountyId], references: [id])
  subCountyId String
  schools     School[]
  villages    Village[]
  createdAt   DateTime  @default(now())

  @@unique([subCountyId, name])
}

// Village (admin5) — the leaf of Uganda's administrative hierarchy. NOT in
// COD-AB; populated from the Uganda Administrative Units Dataset 2022. `source`
// records provenance ("UG-AU-DS-2022").
model Village {
  id        String   @id @default(cuid())
  name      String
  parish    Parish   @relation(fields: [parishId], references: [id])
  parishId  String
  source    String?
  createdAt DateTime @default(now())

  @@unique([parishId, name])
  @@index([parishId])
}

// Alias / known spelling variant for any admin level — drives tolerant matching
// of free-text school uploads without silent fuzzy guesswork.
model GeographyAlias {
  id              String   @id @default(cuid())
  adminLevel      String // region | subRegion | district | county | subCounty | parish
  adminId         String
  alias           String
  normalizedAlias String
  source          String?
  confidence      String? // EXACT | ALIAS | FUZZY_HIGH
  createdAt       DateTime @default(now())

  @@unique([adminLevel, normalizedAlias])
  @@index([adminLevel, adminId])
}

// Audit record for each official boundary import — provenance + integrity.
model BoundaryImportRun {
  id                 String   @id @default(cuid())
  sourceName         String
  sourceUrl          String?
  sourceLastModified String?
  importedAt         DateTime @default(now())
  importedBy         String?
  levelCounts        Json // { region, district, county, subCounty, parish }
  checksum           String?
  status             String // SUCCESS | PARTIAL | FAILED
  errors             Json?
  warnings           Json?
}

// ─────────────────────── School Directory ───────────────────────

model School {
  id                       String     @id @default(cuid())
  schoolId                 String     @unique // human/operational id used across the app
  name                     String
  region                   Region     @relation(fields: [regionId], references: [id])
  regionId                 String
  district                 District   @relation(fields: [districtId], references: [id])
  districtId               String
  subCounty                SubCounty? @relation(fields: [subCountyId], references: [id])
  subCountyId              String?
  parish                   Parish?    @relation(fields: [parishId], references: [id])
  parishId                 String?
  // Resolved official sub-region / county ids (plain refs — joined in app code).
  subRegionId              String?
  countyId                 String?
  // Exact school coordinates — null until uploaded/geocoded. When present, the
  // geo-analytics map renders an EXACT pin automatically; otherwise the school
  // is represented in the district's aggregate (bubble at the district centroid).
  latitude                 Float?
  longitude                Float?
  // ORIGINAL uploaded geography text — preserved verbatim for audit + correction,
  // never overwritten by matching. Match status drives the geography review queue.
  uploadedRegionText       String?
  uploadedDistrictText     String?
  uploadedSubCountyText    String?
  uploadedParishText       String?
  geographyMatchStatus     String? // EXACT | ALIAS | FUZZY_HIGH | FUZZY_LOW_REVIEW_REQUIRED | UNMATCHED
  geographyMatchConfidence Float?
  geographyMatchWarnings   Json?

  shippingAddress     String?
  schoolPhone         String?
  primaryContactName  String?
  primaryContactPhone String?
  enrollment          Int?
  schoolType          SchoolType @default(client)

  accountOwner        StaffProfile?      @relation("SchoolAccountOwner", fields: [accountOwnerId], references: [id])
  accountOwnerId      String?
  accountOwnerNameRaw String? // as uploaded, before matching
  accountOwnerStatus  AccountOwnerStatus @default(pending)
  duplicateStatus     DuplicateStatus    @default(none)

  cluster       Cluster?      @relation(fields: [clusterId], references: [id])
  clusterId     String?
  clusterStatus ClusterStatus @default(unclustered)

  currentFySsaStatus SsaStatus         @default(not_done)
  planningReadiness  PlanningReadiness @default(locked)

  // Salesforce-ready (not integrated yet)
  salesforceAccountId    String?
  salesforceSyncStatus   SalesforceSyncStatus @default(not_synced)
  salesforceLastSyncedAt DateTime?
  salesforceSyncError    String?

  createdByIa   Boolean      @default(false)
  uploadBatch   UploadBatch? @relation(fields: [uploadBatchId], references: [id])
  uploadBatchId String?

  portfolioAssignments StaffSchoolAssignment[]
  clusterAssignments   SchoolClusterAssignment[]
  ssaRecords           SsaRecord[]
  enrollmentHistory    SchoolEnrollmentHistory[]
  activities           Activity[]
  duplicateCandidates  SchoolDuplicateCandidate[] @relation("DupSchool")
  duplicateMatches     SchoolDuplicateCandidate[] @relation("DupCandidate")
  projectAssignments   ProjectSchoolAssignment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([regionId])
  @@index([districtId])
  @@index([clusterId])
  @@index([schoolType])
}

model UploadBatch {
  id            String                        @id @default(cuid())
  source        String                        @default("manual") // manual | csv | future:salesforce
  fileName      String?
  uploadedBy    String // userId
  rowCount      Int                           @default(0)
  acceptedCount Int                           @default(0)
  flaggedCount  Int                           @default(0)
  schools       School[]
  ownerMaps     SchoolAccountOwnerUploadMap[]
  createdAt     DateTime                      @default(now())
}

model SchoolAccountOwnerUploadMap {
  id             String      @id @default(cuid())
  uploadBatch    UploadBatch @relation(fields: [uploadBatchId], references: [id])
  uploadBatchId  String
  schoolIdRaw    String
  ownerNameRaw   String
  matchedStaffId String?
  matched        Boolean     @default(false)
  createdAt      DateTime    @default(now())
}

model SchoolDuplicateCandidate {
  id          String   @id @default(cuid())
  school      School   @relation("DupSchool", fields: [schoolId], references: [id])
  schoolId    String
  candidate   School   @relation("DupCandidate", fields: [candidateId], references: [id])
  candidateId String
  score       Int // 0-100 similarity
  reasons     String[] // ["name","phone","district"]
  resolved    Boolean  @default(false)
  resolution  String? // merged | not_duplicate | archived
  createdAt   DateTime @default(now())

  @@unique([schoolId, candidateId])
}

// ─────────────────────── Clusters ───────────────────────

model Cluster {
  id                 String                    @id @default(cuid())
  name               String
  region             Region                    @relation(fields: [regionId], references: [id])
  regionId           String
  district           District                  @relation(fields: [districtId], references: [id])
  districtId         String
  subCounty          SubCounty?                @relation(fields: [subCountyId], references: [id])
  subCountyId        String? // PRIMARY sub-county (first selected); display + back-compat
  subCountyName      String? // display fallback
  clusterType        ClusterType               @default(mixed)
  status             ClusterRecordStatus       @default(active)
  overrideReason     String? // set when created via sub-county uniqueness override
  responsibleStaffId String?
  clusterLeaderName  String?
  clusterLeaderPhone String?
  schools            School[]
  assignments        SchoolClusterAssignment[]
  // A cluster covers ONE OR MORE sub-counties (§4/§5). Eligibility is computed
  // against this set — a school is eligible iff its sub-county is covered.
  coveredSubCounties ClusterSubCounty[]
  activities         Activity[]
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  deletedAt          DateTime?

  @@index([districtId])
  @@index([subCountyId])
}

// Join: the set of sub-counties a cluster covers (supports multi-sub-county
// clusters). The cluster's PRIMARY sub-county is also kept on Cluster.subCountyId
// for display + the historical per-sub-county uniqueness index.
model ClusterSubCounty {
  id          String    @id @default(cuid())
  cluster     Cluster   @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  clusterId   String
  subCounty   SubCounty @relation(fields: [subCountyId], references: [id])
  subCountyId String
  createdAt   DateTime  @default(now())

  @@unique([clusterId, subCountyId])
  @@index([subCountyId])
}

model SchoolClusterAssignment {
  id         String   @id @default(cuid())
  school     School   @relation(fields: [schoolId], references: [id])
  schoolId   String
  cluster    Cluster  @relation(fields: [clusterId], references: [id])
  clusterId  String
  assignedBy String // userId
  createdAt  DateTime @default(now())

  @@unique([schoolId, clusterId])
}

// ─────────────────────── SSA ───────────────────────

model SsaRecord {
  id            String     @id @default(cuid())
  school        School     @relation(fields: [schoolId], references: [id])
  schoolId      String
  dateOfSsa     DateTime
  fy            String
  quarter       String // Q1..Q4
  newEnrollment Int?
  averageScore  Float?
  scores        SsaScore[]

  // Salesforce-ready verification of the SSA itself
  salesforceId       String?
  verificationStatus VerificationStatus @default(pending)

  // Collection source + verification provenance (the contract-worthy QA layer).
  // Staff-collected SSA is auto-verified; partner-collected needs staff/IA review.
  collectorType        SsaCollectorType @default(staff)
  verificationSource   String? // staff_self_verified | partner_submitted | ia_verified | imported_previous_fy
  collectedByUserId    String?
  collectedByPartnerId String?
  verifiedByUserId     String?
  verifiedAt           DateTime?
  qaReviewedByUserId   String?
  qaReviewedAt         DateTime?

  uploadedBy String // userId (IA)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@index([schoolId])
  @@index([fy])
  @@index([collectorType])
  @@index([verificationStatus])
}

enum SsaCollectorType {
  staff
  partner
  ia
  imported_previous_fy
  system_migration
}

model SsaScore {
  id           String          @id @default(cuid())
  ssaRecord    SsaRecord       @relation(fields: [ssaRecordId], references: [id])
  ssaRecordId  String
  intervention SsaIntervention
  score        Float

  @@unique([ssaRecordId, intervention])
}

model SchoolEnrollmentHistory {
  id         String   @id @default(cuid())
  school     School   @relation(fields: [schoolId], references: [id])
  schoolId   String
  fy         String
  enrollment Int
  recordedAt DateTime @default(now())

  @@unique([schoolId, fy])
}

// ─────────────────────── Activities ───────────────────────

model Activity {
  id           String       @id @default(cuid())
  activityType ActivityType
  school       School?      @relation(fields: [schoolId], references: [id])
  schoolId     String?
  cluster      Cluster?     @relation(fields: [clusterId], references: [id])
  clusterId    String?
  project      Project?     @relation(fields: [projectId], references: [id])
  projectId    String?

  fy            String
  quarter       String
  month         Int?
  week          Int?
  scheduledDate DateTime?
  plannedMonth  Int?
  plannedWeek   Int?

  responsibleStaff   StaffProfile?       @relation("ActivityResponsible", fields: [responsibleStaffId], references: [id])
  responsibleStaffId String?
  monitoredByStaff   StaffProfile?       @relation("ActivityMonitor", fields: [monitoredByStaffId], references: [id])
  monitoredByStaffId String?
  assignedPartner    Partner?            @relation(fields: [assignedPartnerId], references: [id])
  assignedPartnerId  String?
  deliveryType       DeliveryType        @default(staff)
  // Explicit cluster slot (SIT / 1st / 2nd / 3rd) when this is cluster work.
  clusterSlot        ClusterMeetingSlot?

  purposeIntervention SsaIntervention?
  status              ActivityStatus   @default(not_planned)
  evidenceStatus      EvidenceStatus   @default(none)

  // Salesforce-ready
  salesforceActivityId   String?
  salesforceActivityType SalesforceActivityType?

  iaVerificationStatus VerificationStatus @default(pending)
  iaConfirmedAt        DateTime?
  iaConfirmedBy        String?
  paymentStatus        PaymentStatus      @default(none)

  // Reschedule trail (plan-as-list): count drives the slip limit.
  rescheduleCount Int     @default(0)
  lastReason      String?

  // Training/cluster-meeting completion detail
  teachersAttended  Int?
  leadersAttended   Int?
  otherParticipants Int?
  nextMeetingDate   DateTime?

  evidence       EvidenceRecord[]
  verification   ActivityCompletionVerification?
  paymentRequest PaymentRequest?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([schoolId])
  @@index([clusterId])
  @@index([fy, quarter])
  @@index([responsibleStaffId])
  @@index([status])
  // Hot-path indexes for the command-center, budget, and accountant queries.
  @@index([scheduledDate])
  @@index([assignedPartnerId])
  @@index([iaVerificationStatus, paymentStatus])
  @@index([evidenceStatus])
}

// ─────────────────────── Evidence ───────────────────────

model EvidenceRecord {
  id           String         @id @default(cuid())
  activity     Activity       @relation(fields: [activityId], references: [id])
  activityId   String
  kind         EvidenceKind
  uri          String
  originalName String? // the uploader's filename (for download + display)
  mimeType     String? // for correct Content-Type on preview/download
  notes        String?
  uploadedBy   String // userId (staff or partner)
  status       EvidenceStatus @default(uploaded)
  reviewedBy   String?
  reviewedAt   DateTime?
  reviewNote   String?
  // Malware-scan seam (spec §11). scanStatus: pending | clean | infected |
  // skipped (no scanner configured). A quarantined file is never downloadable.
  scanStatus   String         @default("pending")
  quarantined  Boolean        @default(false)
  createdAt    DateTime       @default(now())

  @@index([activityId])
  @@index([quarantined])
}

// ─────────────── Salesforce verification (manual) ───────────────

model ActivityCompletionVerification {
  id           String             @id @default(cuid())
  activity     Activity           @relation(fields: [activityId], references: [id])
  activityId   String             @unique
  salesforceId String // SV- or TS-
  enteredBy    String // responsible staff userId
  enteredAt    DateTime           @default(now())
  status       VerificationStatus @default(pending)
  iaActorId    String?
  iaActionAt   DateTime?
  iaNote       String?
}

// ─────────────────────── Payments ───────────────────────

model PaymentRequest {
  id                String               @id @default(cuid())
  activity          Activity             @relation(fields: [activityId], references: [id])
  activityId        String               @unique
  path              PaymentPath
  amount            Float?
  status            PaymentStatus        @default(pending_ia)
  netsuiteExpenseId String?
  actions           PaymentActionLog[]
  disbursement      PaymentDisbursement?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model PaymentActionLog {
  id               String         @id @default(cuid())
  paymentRequest   PaymentRequest @relation(fields: [paymentRequestId], references: [id])
  paymentRequestId String
  action           String // ia_confirmed | pl_approved | accountant_cleared | paid | netsuite_recorded
  actorId          String
  note             String?
  createdAt        DateTime       @default(now())
}

model PaymentDisbursement {
  id               String         @id @default(cuid())
  paymentRequest   PaymentRequest @relation(fields: [paymentRequestId], references: [id])
  paymentRequestId String         @unique
  amount           Float
  clearedBy        String // accountant userId
  paidAt           DateTime       @default(now())
  reference        String?
}

// ─────────────────────── Annual plan & budget ───────────────────────

model AnnualPlan {
  id             String               @id @default(cuid())
  fy             String
  ownerStaffId   String?
  status         String               @default("draft") // draft | submitted | approved | returned
  activities     AnnualPlanActivity[]
  budgetVersions BudgetVersion[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([fy, ownerStaffId])
}

// Monthly plan — the CCEO's plan-as-list for one operational month. Separate
// from AnnualPlan (which is FY-level). Activities are plan-scoped drafts; the
// plan carries the approval-workflow status.
model MonthlyPlan {
  id             String                @id @default(cuid())
  monthIso       String // "2026-05"
  ownerStaffId   String
  ownerName      String?
  countryId      String                @default("Uganda")
  // draft | submitted | approved | returned | active | closed
  status         String                @default("draft")
  submittedAt    DateTime?
  approvedAt     DateTime?
  approvedById   String?
  returnedReason String?
  totalCostCents Int                   @default(0)
  activities     MonthlyPlanActivity[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@unique([monthIso, ownerStaffId])
  @@index([status])
  @@index([ownerStaffId])
}

model MonthlyPlanActivity {
  id               String      @id @default(cuid())
  plan             MonthlyPlan @relation(fields: [monthlyPlanId], references: [id], onDelete: Cascade)
  monthlyPlanId    String
  kind             String
  title            String
  weekOfMonth      Int         @default(1)
  scheduledDate    String?
  schoolId         String?
  assigneeId       String?
  estCostCents     Int         @default(0)
  status           String      @default("Planned")
  interventionArea String?
  deliveryType     String?
  partnerName      String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([monthlyPlanId])
}

// Core-school plan — one per onboarded core school (4 visits + 4 trainings).
// Deterministic id "cplan-{schoolId}" so the FE core-store and the backend
// share ids (no mapping drift).
model CorePlan {
  id                 String             @id // "cplan-{schoolId}"
  schoolId           String             @unique // operational schoolId
  fy                 String
  status             String             @default("Active")
  visitsTarget       Int                @default(4)
  trainingsTarget    Int                @default(4)
  visitsCompleted    Int                @default(0)
  trainingsCompleted Int                @default(0)
  baselineAverage    Float?
  followUpAverage    Float?
  interventions      Json? // [{ area, rank, baselineScore }]
  createdById        String?
  createdByName      String?
  slots              CoreActivitySlot[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([status])
}

// The 8 core slots (4 visit + 4 training). Deterministic id
// "cslot-{schoolId}-{v|t}{seq}" to match the FE core-store.
model CoreActivitySlot {
  id                  String    @id // "cslot-{schoolId}-v1"
  corePlan            CorePlan  @relation(fields: [corePlanId], references: [id], onDelete: Cascade)
  corePlanId          String
  schoolId            String
  intervention        String
  activityType        String // "visit" | "training"
  sequenceNumber      Int
  status              String    @default("Planned")
  owner               String    @default("unassigned") // unassigned|myself|staff|partner
  assignedStaffId     String?
  assignedStaffName   String?
  assignedPartnerId   String?
  assignedPartnerName String?
  scheduledMonth      String?
  scheduledWeek       Int?
  salesforceId        String?
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([corePlanId])
  @@index([schoolId])
}

model AnnualPlanActivity {
  id           String               @id @default(cuid())
  annualPlan   AnnualPlan           @relation(fields: [annualPlanId], references: [id])
  annualPlanId String
  activityType ActivityType
  schoolId     String?
  clusterId    String?
  quarter      String
  month        Int?
  week         Int?
  budgetLines  ActivityBudgetLine[]
  createdAt    DateTime             @default(now())
}

model ActivityBudgetLine {
  id                   String             @id @default(cuid())
  annualPlanActivity   AnnualPlanActivity @relation(fields: [annualPlanActivityId], references: [id])
  annualPlanActivityId String
  costSettingKey       String
  quantity             Float              @default(1)
  unitCost             Float
  amount               Float
  createdAt            DateTime           @default(now())
}

model BudgetVersion {
  id           String           @id @default(cuid())
  annualPlan   AnnualPlan       @relation(fields: [annualPlanId], references: [id])
  annualPlanId String
  version      Int              @default(1)
  total        Float            @default(0)
  approvals    BudgetApproval[]
  createdAt    DateTime         @default(now())
}

model BudgetApproval {
  id              String        @id @default(cuid())
  budgetVersion   BudgetVersion @relation(fields: [budgetVersionId], references: [id])
  budgetVersionId String
  approverId      String
  decision        String // approved | returned
  note            String?
  createdAt       DateTime      @default(now())
}

model MonthlyFundRequest {
  id        String   @id @default(cuid())
  fy        String
  month     Int
  staffId   String?
  amount    Float
  status    String   @default("submitted")
  createdAt DateTime @default(now())
}

model CostSetting {
  id        String   @id @default(cuid())
  key       String   @unique // staff_visit_transport_primary, lunch, partner_visit_lump_sum, ...
  label     String
  unitCost  Float
  fy        String?
  version   Int      @default(1) // bumped on every rate change (CountryCostRegister versioning)
  createdBy String? // CD userId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Versioned, append-only change history for the CD Country Cost Register. Every
// rate change records old→new, who, when and why, so past budgets (which snapshot
// unitCost on the ActivityBudgetLine) can always be reconciled to the version
// that produced them.
model CostSettingHistory {
  id              String   @id @default(cuid())
  key             String
  label           String
  oldUnitCost     Float? // null on first create
  newUnitCost     Float
  version         Int // the new version after this change
  fy              String?
  changedByUserId String
  reason          String?
  changedAt       DateTime @default(now())

  @@index([key])
  @@index([changedAt])
}

// ─────────────────────── Special projects ───────────────────────

model Project {
  id                 String                     @id @default(cuid())
  // Stable business code (e.g. "SP-EDTECH") — the cross-surface identifier the
  // School Directory / portfolio uses to assign schools. Lets the FE reference a
  // project without knowing its cuid, so assignment writes hit the real backend.
  code               String?                    @unique
  name               String
  category           ProjectCategory
  intervention       SsaIntervention?
  managerStaffId     String?
  schoolAssignments  ProjectSchoolAssignment[]
  partnerAssignments ProjectPartnerAssignment[]
  activities         Activity[]
  impactSnapshots    ProjectImpactSnapshot[]
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  deletedAt          DateTime?
}

model ProjectSchoolAssignment {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  school    School   @relation(fields: [schoolId], references: [id])
  schoolId  String
  createdAt DateTime @default(now())

  @@unique([projectId, schoolId])
}

model ProjectPartnerAssignment {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  partner   Partner  @relation(fields: [partnerId], references: [id])
  partnerId String
  createdAt DateTime @default(now())

  @@unique([projectId, partnerId])
}

model ProjectImpactSnapshot {
  id          String   @id @default(cuid())
  project     Project  @relation(fields: [projectId], references: [id])
  projectId   String
  fy          String
  metricsJson Json
  createdAt   DateTime @default(now())
}

// ─────────────────────── Partners ───────────────────────

model Partner {
  id                  String                      @id @default(cuid())
  name                String
  regionName          String?
  trainsOn            String[]
  notes               String?
  // CD onboarding profile (item 17/18): eligibility, coverage, contract.
  contactPerson       String?
  email               String?
  phone               String?
  coverageDistricts   String[]
  contractStatus      String? // active | pending | expired | none
  onboardedByUserId   String?
  onboardedAt         DateTime?
  // Certification (item 14): correlation separates certified vs non-certified
  // partner support, driving the staff-vs-certified-partner contribution view.
  isCertified         Boolean                     @default(false)
  certificationStatus String? // certified | pending | expired | none
  expertiseAreas      String[]
  activeStatus        Boolean                     @default(true)
  // Backend login link — a partner field officer authenticates as this user, so
  // their session sees only THIS partner's assigned activities (the round-trip).
  userId              String?                     @unique
  user                User?                       @relation(fields: [userId], references: [id])
  activities          Activity[]
  projectAssignments  ProjectPartnerAssignment[]
  performanceProfiles PartnerPerformanceProfile[]
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  deletedAt           DateTime?
}

// ─────────────────────── Messages & notifications ───────────────────────

model MessageThread {
  id          String    @id @default(cuid())
  subject     String
  contextType String?
  contextId   String?
  messages    Message[]
  createdAt   DateTime  @default(now())
}

model Message {
  id             String               @id @default(cuid())
  thread         MessageThread        @relation(fields: [threadId], references: [id])
  threadId       String
  sender         User                 @relation("MessageSender", fields: [senderId], references: [id])
  senderId       String
  recipientId    String? // the user this message is addressed to (inbox scope)
  body           String
  category       String?
  contextType    String?
  contextId      String?
  targetRoute    String?
  priority       NotificationPriority @default(normal)
  actionRequired Boolean              @default(false)
  status         MessageStatus        @default(unread)
  createdAt      DateTime             @default(now())

  @@index([recipientId, status])
}

model Notification {
  id             String               @id @default(cuid())
  recipient      User                 @relation(fields: [recipientId], references: [id])
  recipientId    String
  title          String
  body           String?
  contextType    String?
  contextId      String?
  targetRoute    String?
  actionRequired Boolean              @default(false)
  priority       NotificationPriority @default(normal)
  status         MessageStatus        @default(unread)
  createdAt      DateTime             @default(now())

  @@index([recipientId, status])
}

// ─────────────────────── Audit ───────────────────────

model AuditLog {
  id            String     @id @default(cuid())
  // Monotonic insert order — the chain is verified in seq order (createdAt ties
  // at ms resolution would otherwise be ambiguous).
  seq           BigInt     @default(autoincrement())
  action        String // "school.upload", "ia.confirm", "authz.deny", ...
  subjectKind   String?
  subjectId     String?
  actor         User?      @relation("AuditActor", fields: [actorId], references: [id])
  actorId       String?
  actorRole     EdifyRole?
  payload       Json?
  // Request provenance (captured via AsyncLocalStorage request context).
  ipAddress     String?
  userAgent     String?
  correlationId String?
  success       Boolean    @default(true)
  reason        String?
  // Tamper-evidence: hash chain. hash = sha256(prevHash + canonical(record));
  // prevHash links to the previous row. A DB trigger blocks UPDATE/DELETE.
  prevHash      String?
  hash          String?
  createdAt     DateTime   @default(now())

  @@index([subjectKind, subjectId])
  @@index([actorId])
  @@index([createdAt])
  @@index([seq])
  @@index([action])
  @@index([correlationId])
}

// ── Target framework ────────────────────────────────────────────────
// CD/IA set annual commitments across every category; the engine resolves
// a 100% default when no explicit setting exists. Targets prove EXECUTION
// (did we do the planned work, on time, verified?), distinct from SSA impact.
enum TargetType {
  SCHOOL_REACH
  STAFF_DIRECT_SUPPORT
  PARTNER_SUPPORT
  TRAINING
  SSA
  SCHOOL_VISIT
  MSCS
  EXAM_RESULTS
  CORE_PACKAGE
  PROJECT_SUPPORT
  IA_VERIFICATION
  ACCOUNTABILITY
}

enum TargetScopeType {
  country
  region
  district
  cluster
  staff
  pl_team
  partner
  project
  school_type
}

enum TargetUnit {
  count
  percentage
}

model TargetSetting {
  id                  String          @id @default(cuid())
  fy                  String
  targetType          TargetType
  scopeType           TargetScopeType
  scopeId             String?
  targetValue         Float?
  targetUnit          TargetUnit      @default(percentage)
  targetPercentage    Float?
  // Optional custom cumulative distribution e.g. {"Q1":0.2,"Q2":0.5,"Q3":0.75,"Q4":1}
  quarterDistribution Json?
  setByUserId         String
  setByRole           EdifyRole
  effectiveFrom       DateTime        @default(now())
  effectiveTo         DateTime?
  notes               String?
  isActive            Boolean         @default(true)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([fy, targetType])
  @@index([scopeType, scopeId])
  @@index([isActive])
}

// ── Most Significant Change Stories ─────────────────────────────────
enum MscsReviewStatus {
  draft
  submitted
  reviewed
  approved
  returned
  rejected
  donor_ready
}

model MostSignificantChangeStory {
  id                    String           @id @default(cuid())
  fy                    String
  quarter               String?
  schoolId              String?
  clusterId             String?
  districtId            String?
  regionId              String?
  submittedByStaffId    String?
  submittedByRole       EdifyRole?
  relatedInterventionId String?
  relatedProjectId      String?
  storyTitle            String
  storySummary          String?
  storyText             String?
  evidenceAttachmentId  String?
  consentStatus         String?
  reviewStatus          MscsReviewStatus @default(draft)
  reviewedBy            String?
  approvedBy            String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  deletedAt             DateTime?

  @@index([fy, quarter])
  @@index([schoolId])
  @@index([reviewStatus])
}

// ── Exam Results collection ─────────────────────────────────────────
enum ExamCollectionStatus {
  missing
  collected
  validated
  returned
  approved
}

model ExamResultCollection {
  id                 String               @id @default(cuid())
  schoolId           String
  fy                 String
  examType           String?
  examYear           Int?
  collectionDate     DateTime?
  collectedByStaffId String?
  uploadedByIA       String?
  status             ExamCollectionStatus @default(missing)
  attachmentId       String?
  resultsSummaryJson Json?
  notes              String?
  createdAt          DateTime             @default(now())
