  @@index([schoolId])
  @@index([status])
}

// ── Daily Debrief — the daily field-truth record ────────────────────
// Not a UI note: an official operational record. Staff (CCEO/PL) debriefs route
// up to PL/CD/IA/HR; partner debriefs route first to the responsible CCEO, who
// reviews + merges them before the combined record routes upward.
enum DebriefType {
  staff
  partner
  merged
}

enum DebriefStatus {
  draft
  submitted
  reviewed
  merged
  returned
  archived
}

model DailyDebrief {
  id                  String        @id @default(cuid())
  fy                  String
  date                DateTime // the field day this debrief covers
  submittedByUserId   String
  submittedByRole     EdifyRole
  staffId             String? // StaffProfile id (staff debrief)
  partnerId           String? // Partner id (partner debrief)
  debriefType         DebriefType   @default(staff)
  status              DebriefStatus @default(submitted)
  summary             String?
  whatHappened        String?
  whatWentWell        String?
  whatDidNotGoWell    String?
  blockers            String[] // blocker keys (no_funds, transport_late, …)
  blockerOther        String?
  supportNeeded       String?
  recommendations     String?
  nextAction          String?
  linkedSchoolIds     String[]
  linkedClusterIds    String[]
  linkedPartnerIds    String[]
  linkedProjectIds    String[]
  linkedActivityIds   String[]
  parentDebriefId     String? // a merged debrief's staff parent
  mergedIntoDebriefId String? // set on a partner debrief once merged
  reviewedByUserId    String?
  reviewedAt          DateTime?
  reviewNote          String?
  submittedAt         DateTime      @default(now())
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  recipients DailyDebriefRecipient[]

  @@index([fy, date])
  @@index([submittedByUserId])
  @@index([status])
  @@index([partnerId])
}

model DailyDebriefRecipient {
  id              String       @id @default(cuid())
  debrief         DailyDebrief @relation(fields: [debriefId], references: [id])
  debriefId       String
  recipientUserId String
  recipientRole   EdifyRole
  routingReason   String?
  actionRequired  Boolean      @default(false)
  readAt          DateTime?
  createdAt       DateTime     @default(now())

  @@index([recipientUserId, readAt])
  @@index([debriefId])
}

// ── Fund requests (the Budget → Fund Request stage) ──────────────────────────
// A submitted snapshot of a period's scheduled-and-costed work, routed for
// approval. The amount is computed from the schedule at submit time (never
// typed); a request with any cost-missing activity is blocked from submission.
enum FundRequestPeriod {
  weekly
  monthly
  quarterly
  annual
}

enum FundRequestStatus {
  submitted
  approved
  returned
  rejected
  disbursed
}

model FundRequest {
  id                        String            @id @default(cuid())
  fy                        String
  period                    FundRequestPeriod
  periodKey                 String // e.g. "2026" | "2026-Q3" | "2026-M2"
  scope                     String // own | team | country (the submitter's lens)
  submittedByUserId         String
  submittedByRole           EdifyRole
  totalAmount               Float
  activityCount             Int
  status                    FundRequestStatus @default(submitted)
  reviewedByUserId          String?
  reviewedAt                DateTime?
  reviewNote                String?
  // Disbursement (accountant clears an APPROVED request → status disbursed).
  disbursedAmount           Float?
  disbursedAt               DateTime?
  disbursedByUserId         String?
  disburseMethod            String? // MobileMoney | BankTransfer | Cash | Cheque
  disburseReference         String?
  // Accountability (owner accounts for spend after disbursement).
  accountedAmount           Float?
  returnedAmount            Float?
  accountabilityStatus      String? // none | submitted | approved | returned
  accountabilityNetsuiteId  String?
  accountabilitySubmittedAt DateTime?
  accountabilityReviewedAt  DateTime?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt

  @@index([status])
  @@index([fy, period])
  @@index([submittedByUserId])
}

// ───────────────────────── Leadership Decision Engine ─────────────────────────
// The engine RECOMMENDS; leadership DECIDES. Nothing here auto-executes an
// employment, MOU, recruitment, or hiring action. Every insight carries
// evidence, a confidence level derived from data completeness, a fairness/
// context adjustment, and a human-review status + audit trail.

enum DecisionType {
  recruitment // School Recruitment Decision Board
  staff_addition // Staff Addition Decision Board
  partner // Partner Decision Board (MOU renew/condition/terminate)
  staff_hr // Staff Performance & HR Decision Board
  regional_investment // Regional / District Investment Decision Board
}

enum DecisionScopeType {
  country
  region
  district
  sub_county
  cluster
  school
  staff
  partner
}

enum DecisionRiskLevel {
  low
  medium
  high
  critical
}

// Confidence is driven by DATA COMPLETENESS — never generate a strong
// recommendation from weak data. `insufficient` = do not act, gather data.
enum DecisionConfidenceLevel {
  high
  medium
  low
  insufficient
}

enum DecisionStatus {
  new
  under_review
  accepted
  accepted_with_conditions
  rejected
  deferred
  converted_to_action_plan
}

// A single generated leadership recommendation. Regenerated by the engine on
// recompute; human-review fields + notes persist the leadership decision layer.
model LeadershipDecisionInsight {
  id           String            @id @default(cuid())
  fy           String
  quarter      String? // Q1..Q4 or null for full-year
  decisionType DecisionType
  scopeType    DecisionScopeType
  scopeId      String? // null for country-wide
  scopeName    String? // denormalized label for display (district/partner/staff name)

  recommendation       String // the headline action, e.g. "Pause recruitment in Lira District"
  reason               String // the "because" summary
  riskLevel            DecisionRiskLevel
  confidenceLevel      DecisionConfidenceLevel
  confidenceScore      Float // 0..100, from DataConfidenceService
  evidenceSummary      Json? // denormalized top evidence points for quick render
  contextAdjustment    String? // fairness/context note (e.g. "high rural workload")
  financialImplication String?
  suggestedAction      String // recommended next LEADERSHIP action (not auto-executed)
  alternatives         Json? // the decision options leadership may choose from
  metrics              Json? // supporting metrics snapshot
  riskFlags            String[] // short risk tags

  status           DecisionStatus @default(new)
  reviewedByUserId String?
  reviewedByRole   EdifyRole?
  reviewedAt       DateTime?
  reviewNote       String?

  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  evidencePoints DecisionEvidencePoint[]
  notes          DecisionNote[]

  @@index([fy, decisionType])
  @@index([scopeType, scopeId])
  @@index([status])
  @@index([riskLevel])
  @@index([confidenceLevel])
}

// One quantified evidence point behind an insight ("38% of schools missing SSA").
model DecisionEvidencePoint {
  id              String                    @id @default(cuid())
  insight         LeadershipDecisionInsight @relation(fields: [insightId], references: [id], onDelete: Cascade)
  insightId       String
  metricName      String
  metricValue     String // string for flexibility ("42%", "18 schools", "0.6 pts")
  comparisonValue String?
  sourceType      String // ssa | targets | workload | partner | system_health | correlation | budget
  sourceId        String?
  explanation     String?
  weight          String                    @default("supporting") // primary | supporting | context
  tone            String? // red | amber | green
  createdAt       DateTime                  @default(now())

  @@index([insightId])
}

// Human review note / leadership decision-trail entry on an insight.
model DecisionNote {
  id           String                    @id @default(cuid())
  insight      LeadershipDecisionInsight @relation(fields: [insightId], references: [id], onDelete: Cascade)
  insightId    String
  authorUserId String
  authorRole   EdifyRole
  note         String
  kind         String                    @default("note") // note | follow_up | condition | decision
  createdAt    DateTime                  @default(now())

  @@index([insightId])
}

// Per-staff workload + difficulty context (the fairness model). ruralityScore /
// distanceBurden are NULLABLE — null means "insufficient data" (no rural/urban
// classification / no coordinates yet) so the engine never fakes context.
model StaffContextProfile {
  id      String       @id @default(cuid())
  staff   StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  staffId String
  fy      String
  quarter String       @default("FY") // Q1..Q4 or "FY"

  schoolLoad            Int @default(0)
  clientSchoolLoad      Int @default(0)
  coreSchoolLoad        Int @default(0)
  partnerManagementLoad Int @default(0)
  projectLoad           Int @default(0)
  districtSpread        Int @default(0)
  subCountySpread       Int @default(0)
  rescheduleLoad        Int @default(0)
  evidenceBacklog       Int @default(0)

  geographyDifficulty    Float  @default(0) // 0..100 from spread (proxy)
  ruralityScore          Float? // null = insufficient data (no rural/urban field)
  distanceBurden         Float? // null = insufficient data (no coordinates)
  teamContributionScore  Float  @default(0)
  contextDifficultyScore Float  @default(0) // composite 0..100
  dataConfidence         Float  @default(0)

  computedAt DateTime @default(now())

  @@unique([staffId, fy, quarter])
  @@index([fy])
}

// Per-partner performance, measured ONLY against the partner's assigned
// interventions. interventionImpactScore is NULLABLE — null when there are too
// few prev→current SSA pairs to judge impact (insufficient data).
model PartnerPerformanceProfile {
  id        String  @id @default(cuid())
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId String
  fy        String
  quarter   String  @default("FY")

  assignedActivities      Int      @default(0)
  completedActivities     Int      @default(0)
  targetAchievementRate   Float    @default(0) // 0..100
  evidenceAcceptanceRate  Float    @default(0)
  iaConfirmationRate      Float    @default(0)
  returnedEvidenceCount   Int      @default(0)
  rescheduleRate          Float    @default(0)
  overdueRate             Float    @default(0)
  capacityUtilization     Float    @default(0)
  interventionImpactScore Float? // null = insufficient SSA pairs to judge
  assignedInterventions   String[]
  recommendationStatus    String? // engine hint (renew | renew_with_conditions | improve | reduce | pause | terminate_review)
  dataConfidence          Float    @default(0)

  computedAt DateTime @default(now())

  @@unique([partnerId, fy, quarter])
  @@index([fy])
}

// Per-scope (region/district/...) recruitment readiness inputs. scopeId is
// non-null with "" = the whole country, so the unique upsert key is stable.
model RecruitmentReadinessProfile {
  id        String            @id @default(cuid())
  scopeType DecisionScopeType
  scopeId   String            @default("") // "" = country-wide
  scopeName String?
  fy        String
  quarter   String            @default("FY")

  ssaCompletionRate         Float   @default(0)
  targetAchievementRate     Float   @default(0)
  staffCapacityScore        Float   @default(0)
  partnerCapacityScore      Float   @default(0)
  dataQualityScore          Float   @default(0)
  impactScore               Float? // null = no prev-FY comparison available
  schoolsTotal              Int     @default(0)
  schoolsMissingSsa         Int     @default(0)
  schoolsUnclustered        Int     @default(0)
  recruitmentRecommendation String?
  dataConfidence            Float   @default(0)

  computedAt DateTime @default(now())

  @@unique([scopeType, scopeId, fy, quarter])
  @@index([fy])
}

// ── Budget Intelligence & Financial Decision Engine ─────────────────────────
// The financial twin of the Leadership Decision Engine: connects cost to
// verified activity, target achievement and SSA impact. Recommends reallocation
// / increase / pause / review — never auto-executes a finance action.
enum ImpactYield {
  high
  healthy
  weak
  low
  insufficient
}

model BudgetIntelligenceInsight {
  id          String            @id @default(cuid())
  fy          String
  periodType  String // month | quarter | fy | week
  period      String // e.g. "2026-03" | "Q3" | "FY"
  insightType String // monthly | partner | activity | regional | accountability | reallocation
  scopeType   DecisionScopeType
  scopeId     String?
  scopeName   String?

  recommendation       String
  reason               String
  riskLevel            DecisionRiskLevel
  impactYield          ImpactYield
  confidenceLevel      DecisionConfidenceLevel
  confidenceScore      Float
  amountAffected       Float? // UGX exposed to this decision
  evidenceSummary      Json?
  financialImplication String?
  suggestedAction      String
  alternatives         Json?
  metrics              Json?
  riskFlags            String[]

  status           DecisionStatus @default(new)
  reviewedByUserId String?
  reviewedByRole   EdifyRole?
  reviewedAt       DateTime?
  reviewNote       String?

  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  notes FinanceDecisionNote[]

  @@index([fy, insightType])
  @@index([scopeType, scopeId])
  @@index([status])
  @@index([impactYield])
}

model FinanceDecisionNote {
  id           String                    @id @default(cuid())
  insight      BudgetIntelligenceInsight @relation(fields: [insightId], references: [id], onDelete: Cascade)
  insightId    String
  authorUserId String
  authorRole   EdifyRole
  note         String
  kind         String                    @default("note") // note | follow_up | decision
  createdAt    DateTime                  @default(now())

  @@index([insightId])
}

// ── CD → PL flag handoff ────────────────────────────────────────────────────
// The Country Director MONITORS + flags issues to a Program Lead (who plans),
// instead of planning directly. A flag is a persisted, PL-assigned action item
// with a notification — never a field-planning action by the CD.
enum CdFlagStatus {
  open
  acknowledged
  resolved
}

model CdFlag {
  id                String       @id @default(cuid())
  raisedByUserId    String // the CD
  raisedByName      String?
  assignedToUserId  String // the Program Lead
  category          String // ssa | target | partner | staff | cluster | fund | evidence | data_quality | core_package
  scopeType         String? // region | district | cluster | school | staff | partner
  scopeId           String?
  scopeName         String?
  note              String
  recommendedAction String?
  priority          String       @default("normal") // low | normal | high | urgent
  dueDate           String?
  status            CdFlagStatus @default(open)
  resolutionNote    String?
  resolvedAt        DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([assignedToUserId, status])
  @@index([raisedByUserId])
}
